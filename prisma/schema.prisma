generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  PLAYER
}

enum TournamentStatus {
  UPCOMING
  ONGOING
  FINISHED
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
}

enum UserStatus {
  PENDING
  ACTIVE
  DISABLED
}

enum InvitationStatus {
  PENDING
  USED
  REVOKED
  EXPIRED
}

model User {
  id           String  @id @default(uuid())
  email        String  @unique
  passwordHash String?
  firstName    String?
  lastName     String?

  role      UserRole   @default(PLAYER)
  status    UserStatus @default(PENDING)
  createdAt DateTime   @default(now())

  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  bets             Bet[]
  tournaments      TournamentParticipant[]
  bonusPredictions BonusPrediction[]
}

model Invitation {
  id     String           @id @default(uuid())
  email  String
  token  String           @unique
  status InvitationStatus @default(PENDING)

  expiresAt DateTime
  usedAt    DateTime?
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([status])
}

model Tournament {
  id        String           @id @default(uuid())
  name      String
  apiCode   String           @unique
  status    TournamentStatus @default(UPCOMING)
  createdAt DateTime         @default(now())

  bonusPredictions BonusPrediction[]
  matches          Match[]
  participants     TournamentParticipant[]
  standings        Standing[]
  topScorers       TopScorer[]
  teams            TournamentTeam[]
  players          TournamentPlayer[]
}

model TournamentParticipant {
  id           String   @id @default(uuid())
  tournamentId String
  userId       String
  joinedAt     DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId])
  @@index([userId])
  @@index([tournamentId])
}

model Match {
  id           String      @id @default(uuid())
  tournamentId String
  apiMatchId   String      @unique
  homeTeam     String?
  awayTeam     String?
  homeTeamLogo String?
  awayTeamLogo String?
  startTime    DateTime
  status       MatchStatus @default(SCHEDULED)
  homeScore    Int?
  awayScore    Int?
  stage        String
  group        String?
  matchday     Int?

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  bets       Bet[]

  @@index([tournamentId])
}

model Bet {
  id           String   @id @default(uuid())
  userId       String
  matchId      String
  homeScore    Int
  awayScore    Int
  pointsEarned Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [apiMatchId], onDelete: Cascade)

  @@index([userId])
  @@index([matchId])
}

model Standing {
  id             String  @id @default(uuid())
  tournamentId   String
  position       Int
  apiTeamId      Int
  teamName       String
  teamCrest      String?
  playedGames    Int
  won            Int
  draw           Int
  lost           Int
  points         Int
  goalsFor       Int
  goalsAgainst   Int
  goalDifference Int

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, apiTeamId])
  @@index([tournamentId])
}

model TopScorer {
  id           String  @id @default(uuid())
  tournamentId String
  apiPlayerId  Int
  playerName   String
  teamName     String
  teamCrest    String?
  goals        Int
  assists      Int?    @default(0)
  penalties    Int?    @default(0)

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, apiPlayerId])
  @@index([tournamentId])
}

enum PredictionType {
  CHAMPION
  RUNNER_UP
  THIRD_PLACE
  TOP_SCORER
}

enum PredictionStatus {
  PENDING
  CORRECT
  INCORRECT
}

model Team {
  id               Int               @id
  name             String
  code             String
  logo             String
  players          Player[]
  bonusPredictions BonusPrediction[]
  tournaments      TournamentTeam[]
}

model Player {
  id               Int                @id
  name             String
  position         String
  dateOfBirth      String?
  nationality      String?
  teamId           Int
  team             Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)
  bonusPredictions BonusPrediction[]
  players          TournamentPlayer[]
}

model BonusPrediction {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type         PredictionType
  status       PredictionStatus @default(PENDING)
  pointsWorth  Int              @default(10)
  pointsEarned Int?

  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  predictedTeamId Int?
  predictedTeam   Team? @relation(fields: [predictedTeamId], references: [id], onDelete: SetNull)

  predictedPlayerId Int?
  predictedPlayer   Player? @relation(fields: [predictedPlayerId], references: [id], onDelete: SetNull)

  predictionValue String
  predictionLogo  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, type])
}

model TournamentTeam {
  tournamentId String
  teamId       Int

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team       Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([tournamentId, teamId])
}

model TournamentPlayer {
  tournamentId String
  playerId     Int

  tournament Tournament @relation(fields: [tournamentId], references: [id])
  player     Player     @relation(fields: [playerId], references: [id])

  @@id([tournamentId, playerId])
}
