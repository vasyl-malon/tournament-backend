generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  PLAYER
}

enum TournamentStatus {
  UPCOMING
  ONGOING
  FINISHED
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
}

enum UserStatus {
  PENDING
  ACTIVE
  DISABLED
}

enum InvitationStatus {
  PENDING
  USED
  REVOKED
  EXPIRED
}

model User {
  id           String  @id @default(uuid())
  email        String  @unique
  passwordHash String?
  firstName    String?
  lastName     String?

  role      UserRole   @default(PLAYER)
  status    UserStatus @default(PENDING)
  createdAt DateTime   @default(now())

  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  bets             Bet[]
  tournaments      TournamentParticipant[]
  bonusPredictions BonusPrediction[]
}

model Invitation {
  id     String           @id @default(uuid())
  email  String
  token  String           @unique
  status InvitationStatus @default(PENDING)

  expiresAt DateTime
  usedAt    DateTime?
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([email, status])
}

model Tournament {
  id        String           @id @default(uuid())
  name      String
  apiCode   String           @unique
  status    TournamentStatus @default(UPCOMING)
  createdAt DateTime         @default(now())
  emblem    String?

  championTeamWorth Int?
  runnerUpTeamWorth Int?
  topScorerWorth    Int?

  championTeamId Int?
  championTeam   Team? @relation("TournamentChampion", fields: [championTeamId], references: [id])

  runnerUpTeamId Int?
  runnerUpTeam   Team? @relation("TournamentRunnerUp", fields: [runnerUpTeamId], references: [id])

  topScorerId Int?
  topScorer   Player? @relation("TournamentTopScorer", fields: [topScorerId], references: [id])

  bonusPredictions BonusPrediction[]
  matches          Match[]
  participants     TournamentParticipant[]
  standings        Standing[]
  topScorers       TopScorer[]
  teams            TournamentTeam[]
  players          TournamentPlayer[]
}

model TournamentParticipant {
  id           String   @id @default(uuid())
  tournamentId String
  userId       String
  joinedAt     DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId])
  @@index([userId, tournamentId])
}

model Match {
  id           String @id @default(uuid())
  tournamentId String
  apiMatchId   String @unique

  homeTeamId      Int?
  awayTeamId      Int?
  advancingTeamId Int?

  startTime    DateTime
  status       MatchStatus @default(SCHEDULED)
  homeScore    Int?
  awayScore    Int?
  homeScorePen Int?
  awayScorePen Int?
  duration     String?
  stage        String
  group        String?
  matchday     Int?

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  bets       Bet[]

  homeTeam      Team? @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam      Team? @relation("AwayTeam", fields: [awayTeamId], references: [id])
  advancingTeam Team? @relation("AdvancingTeam", fields: [advancingTeamId], references: [id])

  @@index([tournamentId])
}

model Bet {
  id                       String   @id @default(uuid())
  userId                   String
  matchId                  String
  homeScore                Int
  awayScore                Int
  predictedAdvancingTeamId Int?
  pointsEarned             Int      @default(0)
  advancingPointsEarned    Int      @default(0)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [apiMatchId], onDelete: Cascade)

  @@unique([userId, matchId])
}

model Team {
  id   Int    @id
  name String
  code String
  logo String

  homeMatches      Match[] @relation("HomeTeam")
  awayMatches      Match[] @relation("AwayTeam")
  advancingMatches Match[] @relation("AdvancingTeam")

  players     Player[]
  tournaments TournamentTeam[]

  championPredictions BonusPrediction[] @relation("PredictionChampion")
  runnerUpPredictions BonusPrediction[] @relation("PredictionRunnerUp")

  championTournaments Tournament[] @relation("TournamentChampion")
  runnerUpTournaments Tournament[] @relation("TournamentRunnerUp")
}

model Player {
  id               Int                @id
  name             String
  position         String
  dateOfBirth      String?
  nationality      String?
  teamId           Int
  team             Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)
  bonusPredictions BonusPrediction[]
  players          TournamentPlayer[]

  topScorerTournaments Tournament[] @relation("TournamentTopScorer")
}

model BonusPrediction {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  championTeamId Int?
  championTeam   Team? @relation("PredictionChampion", fields: [championTeamId], references: [id], onDelete: Cascade)

  runnerUpTeamId Int?
  runnerUpTeam   Team? @relation("PredictionRunnerUp", fields: [runnerUpTeamId], references: [id], onDelete: Cascade)

  topScorerId Int?
  topScorer   Player? @relation(fields: [topScorerId], references: [id], onDelete: Cascade)

  championTeamPoints Int?
  runnerUpTeamPoints Int?
  topScorerPoints    Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, tournamentId])
}

model TournamentTeam {
  tournamentId String
  teamId       Int

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team       Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([tournamentId, teamId])
}

model TournamentPlayer {
  tournamentId String
  playerId     Int

  tournament Tournament @relation(fields: [tournamentId], references: [id])
  player     Player     @relation(fields: [playerId], references: [id])

  @@id([tournamentId, playerId])
}

// TODO: implement later
model Standing {
  id             String  @id @default(uuid())
  tournamentId   String
  position       Int
  apiTeamId      Int
  teamName       String
  teamCrest      String?
  playedGames    Int
  won            Int
  draw           Int
  lost           Int
  points         Int
  goalsFor       Int
  goalsAgainst   Int
  goalDifference Int

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, apiTeamId])
  @@index([tournamentId])
}

model TopScorer {
  id           String  @id @default(uuid())
  tournamentId String
  apiPlayerId  Int
  playerName   String
  teamName     String
  teamCrest    String?
  goals        Int
  assists      Int?    @default(0)
  penalties    Int?    @default(0)

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, apiPlayerId])
  @@index([tournamentId])
}
